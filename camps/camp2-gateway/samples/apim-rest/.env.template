# Copy to .env (do not commit .env) and fill in customer values.

# Required
SUBSCRIPTION_ID=<subscription-guid>
RESOURCE_GROUP=<resource-group-name>
APIM_NAME=<apim-service-name>
SHERPA_SERVER_URL=<https://your-sherpa-server.example.com>

# Optional (for PRM metadata endpoint)
TENANT_ID=<tenant-guid>
MCP_APP_CLIENT_ID=<entra-app-client-id>

# Optional naming overrides
SERVER_NAME=sherpa-mcp
API_PATH=sherpa/mcp
# BACKEND_ID defaults to <SERVER_NAME>-backend when omitted
